# =============================================================================
# Artifact Keeper — Environment Variables Reference
# =============================================================================
# All variables are read by the backend process unless noted otherwise.
# Lines starting with # are comments; uncomment to enable.

# -----------------------------------------------------------------------------
# Database (backend)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://registry:registry@localhost:5432/artifact_registry

# -----------------------------------------------------------------------------
# Server (backend)
# -----------------------------------------------------------------------------
BIND_ADDRESS=0.0.0.0:8080
LOG_LEVEL=info

# Environment (development | production)
# In development mode, CORS automatically allows requests from private-network
# IPs (192.168.x.x, 10.x.x.x, 172.16-31.x.x) and localhost — no extra config
# needed for LAN access.
ENVIRONMENT=development

# Skip automatic database migrations on startup. Set to "true" when
# migrations are applied out-of-band (e.g. via a CI job or init container)
# and you want the backend to start without touching the schema.
# SKIP_MIGRATIONS=false

# CORS allowed origins (comma-separated).
# Only required in production mode or to allow public IPs.
# In development mode this is optional -- private-network origins are auto-allowed.
# CORS_ORIGINS=https://registry.example.com,https://registry-internal.example.com

# gRPC server port (backend, default: 9090)
# GRPC_PORT=9090

# -----------------------------------------------------------------------------
# Storage (backend) — choose one backend
# -----------------------------------------------------------------------------
STORAGE_BACKEND=filesystem
STORAGE_PATH=/var/lib/artifact-keeper/artifacts

# Storage path format: "native" (default), "artifactory" (JFrog-compatible),
# or "migration" (reads both formats during migration).
# STORAGE_PATH_FORMAT=native

# --- S3 Storage (when STORAGE_BACKEND=s3) ---
# S3_BUCKET=my-artifacts
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# S3_PREFIX=artifacts
# S3_ACCESS_KEY_ID=minioadmin       # preferred (S3_* prefix matches other config)
# S3_SECRET_ACCESS_KEY=minioadmin   # falls back to AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
# S3_REDIRECT_DOWNLOADS=false
# S3_PRESIGN_EXPIRY_SECS=3600

# S3 presigned URL credentials (optional, overrides default AWS credentials)
# S3_PRESIGN_ACCESS_KEY_ID=
# S3_PRESIGN_SECRET_ACCESS_KEY=

# S3 TLS Configuration
# S3_CA_CERT_PATH=/etc/ssl/custom-ca.pem  # PEM file with custom CA certificate(s)
# S3_INSECURE_TLS=false                    # Disable TLS verification (dev/test only)

# CloudFront CDN (optional, for S3 backends)
# CLOUDFRONT_DISTRIBUTION_URL=https://dxxxxxxxxxx.cloudfront.net
# CLOUDFRONT_KEY_PAIR_ID=KXXXXXXXXXX
# CLOUDFRONT_PRIVATE_KEY_PATH=/path/to/cloudfront-private-key.pem
# CLOUDFRONT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# --- GCS Storage (when STORAGE_BACKEND=gcs) ---
# GCS_BUCKET=my-artifacts
#
# Option 1: Service account key. Enables redirect downloads via V4 signed URLs.
# Uses the RSA key to mint JWTs exchanged for OAuth2 bearer tokens.
# GCS_PROJECT_ID=my-gcp-project
# GCS_SERVICE_ACCOUNT_EMAIL=sa@project.iam.gserviceaccount.com
# GCS_PRIVATE_KEY_PATH=/path/to/service-account-key.pem
# GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
# GCS_REDIRECT_DOWNLOADS=true
# GCS_SIGNED_URL_EXPIRY=3600
#
# Option 2: Application Default Credentials / Workload Identity.
# Only GCS_BUCKET is required. On GKE with Workload Identity, tokens are
# acquired automatically from the metadata server. Redirect downloads are
# not available in this mode (V4 signed URLs require an RSA private key).

# --- Azure Blob Storage (when STORAGE_BACKEND=azure) ---
# AZURE_STORAGE_ACCOUNT=myaccount
# AZURE_STORAGE_CONTAINER=artifacts
#
# Auth option 1: Shared Key (access key). Supports SAS redirect downloads.
# AZURE_STORAGE_ACCESS_KEY=xxx
#
# Auth option 2: Azure RBAC (service principal). Omit AZURE_STORAGE_ACCESS_KEY
# to activate. The identity needs the "Storage Blob Data Contributor" role.
# AZURE_TENANT_ID=tenant-uuid
# AZURE_CLIENT_ID=client-uuid
# AZURE_CLIENT_SECRET=secret
#
# Auth option 3: Managed Identity. Omit both access key and SP credentials.
# On Azure VMs/AKS/App Service, tokens are acquired automatically via IMDS.
# Set AZURE_CLIENT_ID only for user-assigned managed identity.
#
# AZURE_STORAGE_ENDPOINT=https://myaccount.blob.core.windows.net
# AZURE_REDIRECT_DOWNLOADS=false   # requires Shared Key auth
# AZURE_SAS_EXPIRY=3600

# -----------------------------------------------------------------------------
# Authentication (backend)
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-in-production-use-at-least-32-bytes
JWT_EXPIRATION_SECS=86400
# JWT_ACCESS_TOKEN_EXPIRY_MINUTES=30
# JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Initial admin password. If unset, a random password is generated and written
# to $STORAGE_PATH/admin.password on first boot.
# ADMIN_PASSWORD=

# Set to "true" to skip the built-in admin user on first boot.
# Use this for SSO-only deployments where admin roles are assigned via
# group mapping (OIDC/LDAP/SAML). When set, no local admin account is
# created and admin access must come from an SSO provider group.
# SKIP_ADMIN_PROVISIONING=true

# SSO encryption key for encrypting stored OIDC/LDAP/SAML secrets in the database
# SSO_ENCRYPTION_KEY=

# --- OIDC (optional) ---
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=artifact-registry
# OIDC_CLIENT_SECRET=xxx

# --- LDAP (optional) ---
# LDAP_URL=ldap://ldap.example.com:389
# LDAP_BASE_DN=dc=example,dc=com

# Service account for search-then-bind (recommended for Active Directory)
# LDAP_BIND_DN=cn=service-account,ou=service-accounts,dc=example,dc=com
# LDAP_BIND_PASSWORD=secret

# User search filter. Use {username} or {0} as the placeholder.
# For Active Directory: (sAMAccountName={0})
# For OpenLDAP: (uid={username})
# LDAP_USER_FILTER=(uid={username})

# LDAP attribute names (defaults shown)
# LDAP_USERNAME_ATTR=uid            # AD: sAMAccountName
# LDAP_EMAIL_ATTR=mail
# LDAP_DISPLAY_NAME_ATTR=cn         # AD: displayName
# LDAP_GROUPS_ATTR=memberOf

# Map LDAP group DNs to application roles (semicolon-separated)
# LDAP_GROUP_ROLE_MAP=cn=developers,ou=groups,dc=example,dc=com:developer;cn=ops,ou=groups,dc=example,dc=com:operator

# DN of the LDAP group that grants admin access
# LDAP_ADMIN_GROUP_DN=cn=admins,ou=groups,dc=example,dc=com

# Enable STARTTLS (upgrade plain LDAP connection to TLS)
# LDAP_USE_STARTTLS=false

# Path to a PEM file with custom CA certificates for LDAPS connections.
# Falls back to CUSTOM_CA_CERT_PATH if not set.
# LDAP_CA_CERT_PATH=/etc/ssl/certs/ldap-ca.pem

# Skip TLS certificate verification for LDAP (development only)
# LDAP_INSECURE_TLS=false

# -----------------------------------------------------------------------------
# Security scanning (backend)
# -----------------------------------------------------------------------------
# TRIVY_URL=http://trivy:8080
# OPENSCAP_URL=http://openscap:8080
# OPENSCAP_PROFILE=xccdf_org.ssgproject.content_profile_standard
# SCAN_WORKSPACE_PATH=/scan-workspace
# GITHUB_TOKEN=ghp_xxx

# -----------------------------------------------------------------------------
# Search indexing (backend)
# -----------------------------------------------------------------------------
# MEILISEARCH_URL=http://meilisearch:7700
# MEILISEARCH_API_KEY=masterKey

# -----------------------------------------------------------------------------
# Dependency-Track integration (backend)
# -----------------------------------------------------------------------------
# DEPENDENCY_TRACK_URL=http://dependency-track-apiserver:8080
# DEPENDENCY_TRACK_API_KEY=xxx
# DEPENDENCY_TRACK_ENABLED=true
# DEPENDENCY_TRACK_ADMIN_PASSWORD=ArtifactKeeper2026!

# Dependency-Track proxy (required if DTrack is behind a corporate proxy)
# Without this, NVD vulnerability mirroring will silently fail.
# Supports BASIC, DIGEST, and NTLM authentication.
# DTRACK_HTTP_PROXY_ADDRESS=proxy.example.com
# DTRACK_HTTP_PROXY_PORT=8888
# DTRACK_HTTP_PROXY_USERNAME=
# DTRACK_HTTP_PROXY_PASSWORD=
# DTRACK_NO_PROXY=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Corporate proxy (host-level)
# -----------------------------------------------------------------------------
# The backend uses reqwest, which honours HTTP_PROXY, HTTPS_PROXY, and
# ALL_PROXY natively. The compose files forward these variables into the
# backend container automatically, so setting them here (or exporting them
# on the host) is enough to route outbound traffic through a corporate
# proxy for OIDC discovery, webhook delivery, remote registry proxying,
# and peer mesh communication.
#
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# ALL_PROXY=socks5://proxy.example.com:1080
# NO_PROXY=localhost,127.0.0.1,.internal.com,10.,172.,192.
#
# The compose files also set no_proxy for internal service names (postgres,
# meilisearch, trivy, openscap, dependency-track-apiserver) so
# container-to-container traffic is never routed through the proxy. You
# do not need to add them here.
#
# At startup the backend logs detected proxy env vars at INFO level so you
# can confirm the settings reached the process.

# -----------------------------------------------------------------------------
# Network security (backend)
# -----------------------------------------------------------------------------
# Allow HTTP (non-TLS) connections for remote repository proxying, Artifactory
# migration, and Dependency-Track integration. Required when upstream services
# use plain HTTP (common in air-gapped or development environments).
# Default: false (HTTPS enforced for all external connections)
# ALLOW_HTTP_INTEGRATIONS=false

# Path to a PEM file containing one or more custom CA certificates.
# Used for HTTPS connections to internal services (Artifactory, Nexus,
# remote repositories) that use certificates signed by a private CA.
# Mount the cert file into the container and set this path.
# CUSTOM_CA_CERT_PATH=/etc/ssl/certs/custom-ca.pem

# -----------------------------------------------------------------------------
# Peer mesh networking (backend)
# -----------------------------------------------------------------------------
# PEER_INSTANCE_NAME=primary
# PEER_PUBLIC_ENDPOINT=https://primary.example.com
# PEER_API_KEY=shared-peer-secret

# -----------------------------------------------------------------------------
# WASM plugins (backend)
# -----------------------------------------------------------------------------
# PLUGINS_DIR=./plugins

# -----------------------------------------------------------------------------
# OpenTelemetry (backend, disabled when OTEL_EXPORTER_OTLP_ENDPOINT is unset)
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=artifact-keeper

# -----------------------------------------------------------------------------
# Upload limits (backend)
# -----------------------------------------------------------------------------
# Maximum upload size for artifact uploads (in bytes).
# Default: 10737418240 (10 GB). Set to 0 to disable the limit.
# MAX_UPLOAD_SIZE=10737418240

# -----------------------------------------------------------------------------
# Proxy safeguards (backend)
# -----------------------------------------------------------------------------
# These settings bound peak memory consumption when the proxy service fetches
# artifacts from upstream registries on behalf of remote/proxy repositories.

# Maximum number of concurrent upstream fetches. Each fetch loads the full
# artifact into memory, so this limits how many large downloads can overlap.
# Default: 20. Lower this on memory-constrained hosts.
# PROXY_MAX_CONCURRENT_FETCHES=20

# Maximum artifact size (in bytes) the proxy will accept from upstream.
# Artifacts larger than this are rejected with 502 Bad Gateway.
# Default: 2147483648 (2 GB).
# PROXY_MAX_ARTIFACT_SIZE_BYTES=2147483648

# Seconds to wait for a proxy fetch permit before returning 503.
# When all concurrent fetch slots are in use, new requests queue for up to
# this duration before being rejected.
# Default: 30.
# PROXY_QUEUE_TIMEOUT_SECS=30

# -----------------------------------------------------------------------------
# Rate limiting (backend)
# -----------------------------------------------------------------------------
# The built-in rate limiter is per-instance (in-memory). For multi-instance
# deployments behind a load balancer, configure rate limiting at the ingress
# level (e.g. NGINX limit_req, Envoy, or a cloud WAF) instead.
# RATE_LIMIT_AUTH_PER_MIN=120     # Max auth requests per window (default: 120)
# RATE_LIMIT_API_PER_MIN=5000     # Max API requests per window (default: 5000)
# RATE_LIMIT_WINDOW_SECS=60       # Window duration in seconds (default: 60)
#
# Exempt specific users or service accounts from rate limiting.
# Useful for CI/CD pipelines, automation bots, and shared admin accounts in
# test environments where bcrypt verification under burst auth otherwise
# saturates the spawn_blocking pool and surfaces as 401/429 flakes.
# RATE_LIMIT_EXEMPT_USERNAMES=ci-bot,deploy-bot
# RATE_LIMIT_EXEMPT_SERVICE_ACCOUNTS=false

# -----------------------------------------------------------------------------
# Scheduled tasks (backend)
# -----------------------------------------------------------------------------
# GC_SCHEDULE=0 0 * * * *        # Cron schedule for storage garbage collection (6-field: sec min hour day month weekday). Default: hourly
# LIFECYCLE_CHECK_INTERVAL_SECS=60  # How often to check for due lifecycle policies. Default: 60 seconds
# STUCK_SCAN_THRESHOLD_SECS=1800    # How long a scan_results row may remain in 'running' before the janitor reaps it. Default: 1800 (30 min). Raise above the slowest expected scan.
# STUCK_SCAN_CHECK_INTERVAL_SECS=600  # How often the stuck-scan janitor sweeps. Default: 600 (10 min)

# -----------------------------------------------------------------------------
# Demo mode (backend)
# -----------------------------------------------------------------------------
# DEMO_MODE=false

# -----------------------------------------------------------------------------
# SSO break-glass recovery
# -----------------------------------------------------------------------------
# When SSO is enabled, local login is disabled by default (issue #213).
# Set this to "true" to allow the built-in admin account to log in with
# local credentials even when SSO providers are configured. Useful for
# recovering access when SSO is misconfigured.
# ALLOW_LOCAL_ADMIN_LOGIN=false

# -----------------------------------------------------------------------------
# Edge Node (for edge binary, not the main backend)
# -----------------------------------------------------------------------------
# PRIMARY_URL=https://primary.example.com
# EDGE_API_KEY=xxx
# CACHE_SIZE_MB=1024
